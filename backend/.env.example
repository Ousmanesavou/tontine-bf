# Serveur
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tontine_db
DB_USER=postgres
DB_PASSWORD=your_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=30d

# Africa's Talking (SMS, USSD, Vocal)
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_username
AT_SENDER_ID=TONTINE

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_id

# Orange Money Burkina
ORANGE_MONEY_CLIENT_ID=your_client_id
ORANGE_MONEY_CLIENT_SECRET=your_client_secret
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/bf/v1

# Moov Money Burkina
MOOV_MONEY_API_KEY=your_moov_api_key
MOOV_MONEY_BASE_URL=https://api.moov-africa.bf/v1

# Stockage fichiers (images produits)
STORAGE_BUCKET=tontine-media
STORAGE_URL=https://your-storage-url.com
